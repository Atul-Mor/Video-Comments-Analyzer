    {
      "parameters": {
        "jsCode": "const freq = {};\n\nitems.forEach(item => {\n  let arr = [];\n\n  try {\n    arr = typeof item.json.keywords === \"string\"\n      ? JSON.parse(item.json.keywords)\n      : item.json.keywords || [];\n  } catch {\n    arr = [];\n  }\n\n  arr.forEach(word => {\n    if (!word) return;\n    freq[word] = (freq[word] || 0) + 1;\n  });\n});\n\n// sort + top 10\nconst topKeywords = Object.entries(freq)\n  .sort((a, b) => b[1] - a[1])\n  .slice(0, 10)\n  .map(([k, v]) => ({ keyword: k, count: v }));\n\nreturn [{\n  json: {\n    keywords: topKeywords\n  }\n}];"
      },
