    {
      "parameters": {
        "jsCode": "const result = {\n  sentiment: null,\n  topRequests: null,\n  topComplaints: null,\n  keywords: null,\n  mostEngaged: null\n};\n\nitems.forEach(item => {\n  const data = item.json;\n\n  if (data.sentiment_label || data.count) {\n    result.sentiment = result.sentiment || [];\n    result.sentiment.push(data);\n  }\n\n  if (data.topRequests) {\n    result.topRequests = data.topRequests;\n  }\n\n  if (data.topComplaints) {\n    result.topComplaints = data.topComplaints;\n  }\n\n  if (data.keywords) {\n    result.keywords = data.keywords;\n  }\n\n  if (data.id) {\n    result.mostEngaged = result.mostEngaged || [];\n    result.mostEngaged.push(data);\n  }\n});\n\nreturn [{ json: result }];"
      },
